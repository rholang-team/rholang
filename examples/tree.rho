struct A {
    var l B;
    var r B;

    fun verify(self) bool {
        if (self.l.r.x <= self.r.l.x) {
            if (self.l.l.x <= self.l.r.x) {
                if (self.r.l.x <= self.r.r.x) {
                    return true;
                }
            }
        }
        return false;
    }
}

struct B {
    var l C;
    var r C;
}

struct C {
    var x int;
}
