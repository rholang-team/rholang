struct Pow {
    var x int;
    var n int;

    fun run(self) int {
        var i int = 1;
        var res int = 1;

        while (i <= self.n) {
            res *= self.x;
            i += 1;
        }

        return res;
    }
}

fun square(x int, double bool) int {
    var res int = Pow{.x = x, .n = 2}.run();
    if (double) {
        return res * 2;
    } else {
        return res;
    }
}
